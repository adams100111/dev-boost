# Installer binaries / images — belong on the Ventoy USB, not in git
*.rpm
*.deb
*.AppImage
*.iso

# Secrets — never commit (decrypted at bootstrap from the age file on USB)
secrets.age
*.age
*.env
.env
age-key.txt
.git-credentials
id_ed25519*
id_rsa*

# Generated lock/state may be committed deliberately; local caches are not
*.bak
*.bak.*

# Editor/OS cruft
.DS_Store
.claude/settings.local.json

# subagent-driven-development scratch (briefs, reports, diffs, ledger)
.superpowers/
workstation-config/exports/
*.qcow2
