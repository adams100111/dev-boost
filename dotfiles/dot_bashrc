# ~/.bashrc — dev-boost managed interactive shell configuration.
# devboost — managed by chezmoi; edit via dotfiles/dot_bashrc in the dev-boost repo.
# Do not edit this file manually; re-run `devboost install dotfiles` to reapply.

# If not running interactively, don't do anything.
[[ $- != *i* ]] && return

# ---------------------------------------------------------------------------
# Sensible defaults
# ---------------------------------------------------------------------------
HISTCONTROL=ignoredups:erasedups
HISTSIZE=100000
HISTFILESIZE=200000
shopt -s histappend
shopt -s checkwinsize
shopt -s globstar

# ---------------------------------------------------------------------------
# Path additions (user local bin)
# ---------------------------------------------------------------------------
[[ -d "${HOME}/.local/bin" ]] && export PATH="${HOME}/.local/bin:${PATH}"

# ---------------------------------------------------------------------------
# ripgrep — load the managed config (rg reads config only from this env var)
# ---------------------------------------------------------------------------
export RIPGREP_CONFIG_PATH="${HOME}/.config/ripgrep/ripgreprc"

# ---------------------------------------------------------------------------
# Shell tool initialisers — managed by dev-boost (single copy; no duplication)
# ---------------------------------------------------------------------------

# fzf — sourced FIRST so atuin (below) binds Ctrl-R last and owns it; fzf keeps
# Ctrl-T (files) and Alt-C (cd). Sourcing fzf after atuin steals Ctrl-R from atuin.
[ -f /usr/share/fzf/shell/key-bindings.bash ] && source /usr/share/fzf/shell/key-bindings.bash
[ -f /usr/share/fzf/shell/completion.bash ]   && source /usr/share/fzf/shell/completion.bash
[ -f "${HOME}/.fzf.bash" ] && source "${HOME}/.fzf.bash"

# starship — cross-shell prompt
command -v starship &>/dev/null && eval "$(starship init bash)"

# atuin — shell history search.
# On bash, atuin appends its hooks to precmd_functions/preexec_functions, which
# only exist (and only get invoked) if bash-preexec (or ble.sh) is loaded first.
# Without it, `atuin init bash` binds Ctrl-R but NEVER records commands — atuin
# reads as "not configured". bash-preexec is vendored via dotfiles (dot_bash-preexec.sh)
# so this works on Fedora and Ubuntu alike, not just where atuin's installer drops it.
if command -v atuin &>/dev/null; then
  [ -f "${HOME}/.bash-preexec.sh" ] && source "${HOME}/.bash-preexec.sh"
  eval "$(atuin init bash)"
fi

# zoxide — smarter cd
command -v zoxide &>/dev/null && eval "$(zoxide init bash)"

# direnv — per-directory env
command -v direnv &>/dev/null && eval "$(direnv hook bash)"

# mise — polyglot runtime/version manager; puts managed runtimes (node/python/…)
# on PATH for interactive shells. Without this, mise-installed tools aren't found.
command -v mise &>/dev/null && eval "$(mise activate bash)"

# ---------------------------------------------------------------------------
# dev — hop onto a server and land in a repo, ready to work. Runs ON THE LAPTOP.
#   dev my-vps innovation   → ssh my-vps, attach/create the 'innovation' session in the repo
#   dev my-vps              → a plain 'dev' session in $HOME
#   dev my-vps /srv/app     → an absolute remote path, used as-is
# Repo lookup searches $DEV_REPO_ROOTS (set ON THE SERVER, in ~/.bash_profile/~/.profile;
# default ~/projects:~/repos), first match wins; a named-but-missing repo is a hard error.
# tmux gives one persistent session per repo (attach-or-create, detaching stale clients so
# the view always fits your current screen); without tmux it drops you into a plain shell in
# the repo. Either way you land at a prompt and launch claude/fresh yourself. The resolver
# runs under a remote login shell (bash -lc) so a server-side DEV_REPO_ROOTS export is honored.
if command -v ssh &>/dev/null; then
  dev() {
    local host="${1:?usage: dev HOST [REPO]}"
    local repo="${2-}"
    local script='
set -u
repo=${DEV_REPO:-}
roots=${DEV_REPO_ROOTS:-$HOME/projects:$HOME/repos}
dir=$HOME
if [ -n "$repo" ]; then
  case $repo in
    /*) dir=$repo ;;
    "~"/*) dir=$HOME/${repo#"~"/} ;;
    *)
      found=
      old=$IFS; IFS=:
      for r in $roots; do
        case $r in "~"/*) r=$HOME/${r#"~"/} ;; esac
        [ -d "$r/$repo" ] && { found=$r/$repo; break; }
      done
      IFS=$old
      if [ -n "$found" ]; then dir=$found; else
        printf "dev: repo %s not found in %s\n" "$repo" "$roots" >&2; exit 3
      fi
      ;;
  esac
fi
session=${repo:-dev}; session=${session##*/}; session=${session//[.:]/-}
if command -v tmux >/dev/null 2>&1; then
  exec tmux new-session -A -D -s "$session" -c "$dir"
else
  cd "$dir" || exit 1; exec "${SHELL:-bash}" -i
fi
'
    ssh -t "$host" "DEV_REPO=$(printf '%q' "$repo") bash -lc $(printf '%q' "$script")"
  }
fi

# ---------------------------------------------------------------------------
# Remote dev over Tailscale — publish a VPS port to your other devices, and drive
# a headed browser on your laptop from tests on the VPS. Zero-config one-liners.
# ---------------------------------------------------------------------------
if command -v tailscale &>/dev/null; then
  # expose 3000  → serves it at https://<this-host>.<tailnet>.ts.net (auto-TLS, background)
  expose()   { tailscale serve --bg "${1:?usage: expose PORT}" && tailscale serve status; }
  exposed()  { tailscale serve status; }        # what's currently published
  unexpose() { tailscale serve reset; }          # take it all down
fi

if command -v npx &>/dev/null; then
  # Playwright: watch headed tests on THIS machine's browser, driven from anywhere.
  #   laptop:  pw-server            → opens a headed browser server; prints the pw-connect line
  #   VPS:     pw-connect <ws-url>  → runs `playwright test` against that laptop browser
  pw-server() {
    NODE_PATH="$(npm root -g)" node -e "require('playwright').chromium.launchServer({headless:false,host:'0.0.0.0',port:${PW_PORT:-5000},wsPath:'pw'}).then(function(s){console.log('On the other machine run:  pw-connect '+s.wsEndpoint().replace('0.0.0.0','$(hostname)'))})"
  }
  pw-connect() {
    local ws="${1:?usage: pw-connect ws://LAPTOP:5000/pw}"; shift
    PW_TEST_CONNECT_WS_ENDPOINT="$ws" npx playwright test "$@"
  }
fi

# img2ssh — paste a clipboard IMAGE into an SSH'd CLI (e.g. Claude Code) from ANY terminal,
# not just WezTerm. A clipboard image can't cross SSH, so run this ON THE LAPTOP: it scps the
# clipboard image to HOST and puts the remote PATH back on your clipboard — then paste that
# path into your ssh session (Claude Code renders a path as an [Image]). WezTerm's Ctrl+V does
# this automatically; this is the manual equivalent for GNOME Terminal/Konsole/etc.
# HOST defaults to $DEVBOOST_PASTE_HOST; remote dir to $DEVBOOST_PASTE_DIR (/tmp/wezterm-paste).
if command -v wl-paste &>/dev/null; then
  img2ssh() {
    local host="${1:-${DEVBOOST_PASTE_HOST:?usage: img2ssh HOST (or set DEVBOOST_PASTE_HOST)}}"
    local dir="${DEVBOOST_PASTE_DIR:-/tmp/wezterm-paste}"
    local mime; mime=$(wl-paste --list-types 2>/dev/null | grep -m1 '^image/')
    [ -n "$mime" ] || { echo "img2ssh: no image in the clipboard" >&2; return 1; }
    local path="${dir}/paste-$(date +%Y%m%d-%H%M%S).${mime##*/}"
    wl-paste --type "$mime" | ssh "$host" "mkdir -p '${dir}' && cat > '${path}'" || return 1
    printf '%s' "$path" | wl-copy    # remote path now on the clipboard → paste it in the ssh tab
    echo "${path}  (path copied to clipboard — paste it in your ssh session)"
  }
fi

# ---------------------------------------------------------------------------
# Aliases
# ---------------------------------------------------------------------------
# eza — modern ls (icons, git status, tree); falls back to plain ls if absent.
if command -v eza &>/dev/null; then
  alias ls='eza --group-directories-first'
  alias ll='eza -l --git --group-directories-first'
  alias la='eza -la --git --group-directories-first'
  alias lt='eza --tree --level=2 --group-directories-first'
fi
